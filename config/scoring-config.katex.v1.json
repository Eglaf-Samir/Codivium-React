{
  "version": "codivium.scoring.katex.v1",
  "tracks": {
    "coding_tracks": [
      "micro",
      "interview"
    ],
    "mcq_track": "mcq",
    "pool_categories_across_tracks_for_mastery": false,
    "mcq_contributes_to_depth_in_mastery": false
  },
  "recency": {
    "half_life_days": 15
  },
  "difficulty_factor": {
    "basic": 1.0,
    "intermediate": 1.3,
    "advanced": 1.6
  },
  "coding": {
    "activity_weight": {
      "micro": 1.0,
      "interview": 1.0
    },
    "tries_factor": {
      "min": 0.45,
      "max": 1.0,
      "formula": "clamp(1/sqrt(attempts), min, max)"
    },
    "convergence": {
      "weights": [
        1.0,
        0.92,
        0.85,
        0.78,
        0.7,
        0.6
      ],
      "attempt_bucket": "A=min(attempts,6); 1..5 => A1..A5; >5 => A6"
    },
    "time_factor": {
      "min": 0.6,
      "max": 1.0,
      "Td_minutes": {
        "basic": 90,
        "intermediate": 120,
        "advanced": 160
      },
      "formula": "clamp(exp(-t/Td), min, max)"
    }
  },
  "mcq": {
    "breadth": {
      "gamma": 1.5,
      "uses_recency_decay": true
    },
    "points": {
      "Pmcq": 0.8,
      "formula": "Pmcq*sqrt(U_all)"
    },
    "quiz_constraints": {
      "single_category_per_quiz": true,
      "single_difficulty_per_quiz": true
    }
  },
  "breadth": {
    "tau_E": 1.5,
    "alpha": 0.65,
    "beta": 0.35,
    "confidence_k": {
      "micro": 10,
      "interview": 8,
      "mcq": 14
    },
    "overall_weights": {
      "micro": 0.4,
      "interview": 0.4,
      "mcq": 0.2
    }
  },
  "depth": {
    "lambda": 12,
    "overall_weights": {
      "micro": 0.5,
      "interview": 0.5
    },
    "chart": {
      "lambda_chart": 12,
      "merge_rule": "sum evidence by canonical category key"
    }
  },
  "points": {
    "P0": 4.0,
    "Predo": 2.5,
    "redo_spacing_days": 7
  },
  "efficiency": {
    "epsilon_minutes": 1.0
  },
  "category_key": {
    "primary": "lower(trim(CategoryId))",
    "fallback": "lower(trim(CategoryName))",
    "aliases": {}
  },
  "edge_cases": {
    "when_total_evidence_is_zero_return": 0
  },
  "heatmap": {
    "focus_modes": {
      "default_mode": "impact",
      "top_n_default": 12,
      "top_n_options": [
        8,
        10,
        12,
        14,
        16
      ],
      "impact_weights": {
        "alpha_imp": 0.55,
        "beta_imp": 0.45,
        "_note": "Blend weights for Impact mode: alpha=weakness(convergence), beta=depth weakness. Must sum to 1.0."
      }
    }
  }
}