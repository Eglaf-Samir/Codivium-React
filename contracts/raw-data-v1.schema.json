{
  "$schema": "https://json-schema.org/draft/2020-12/schema",  "title": "Codivium Raw Data Payload v1 (KaTeX-aligned)",  "type": "object",  "additionalProperties": false,  "required": [    "config",    "UniqueCorrectMcqAllTime",    "codingSessionsByTrack",    "mcqAttemptsByTrack"  ],  "properties": {    "config": {      "type": "object",      "additionalProperties": true    },    "UniqueCorrectMcqAllTime": {      "type": "integer",      "minimum": 0,      "description": "KaTeX U_all: lifetime total distinct MCQ questions answered correctly."    },    "mcqDistinctCorrectAllTime": {      "type": "integer",      "minimum": 0,      "description": "Deprecated legacy alias of UniqueCorrectMcqAllTime (accepted for backwards compatibility)."    },    "codingSessionsByTrack": {      "type": "object",      "additionalProperties": {        "type": "array",        "items": {          "$ref": "#/$defs/CodingSession"        }      }    },    "mcqAttemptsByTrack": {      "type": "object",      "additionalProperties": {        "type": "array",        "items": {          "$ref": "#/$defs/McqAttempt"        }      }    }  },  "$defs": {    "Difficulty": {      "oneOf": [        {          "type": "string",          "enum": ["basic", "intermediate", "advanced"]        },        {          "type": "integer",          "enum": [1, 2, 3]        }      ]    },    "UtcDateTime": {      "type": "string",      "format": "date-time"    },    "SubmissionAttempt": {      "type": "object",      "additionalProperties": false,      "required": [        "UnitTestsPassed",        "TimeToSubmissionMinutes"      ],      "properties": {        "UnitTestsPassed": { "type": "integer", "minimum": 0 },        "TimeToSubmissionMinutes": { "type": "number", "minimum": 0 },        "SubmittedAtUtc": { "$ref": "#/$defs/UtcDateTime" }      }    },    "CodingSession": {      "type": "object",      "additionalProperties": false,      "required": [        "ExerciseId",        "Difficulty",        "CompletedAtUtc",        "Attempts",        "TimeToACMinutes"      ],      "anyOf": [        { "required": ["CategoryId"] },        { "required": ["category"] }      ],      "properties": {        "Track": { "type": "string", "minLength": 1 },        "CategoryId": { "type": "string", "minLength": 1 },        "category": { "type": "string", "minLength": 1, "description": "Legacy alias of CategoryId." },        "ExerciseId": { "type": "string", "minLength": 1 },        "Difficulty": { "$ref": "#/$defs/Difficulty" },        "CompletedAtUtc": { "$ref": "#/$defs/UtcDateTime" },        "StartedAtUtc": { "$ref": "#/$defs/UtcDateTime" },        "TimeToACMinutes": { "type": "number", "minimum": 0 },        "UnitTestsTotal": { "type": "integer", "minimum": 0 },        "Attempts": {          "type": "array",          "minItems": 1,          "items": { "$ref": "#/$defs/SubmissionAttempt" }        }      }    },    "McqAttempt": {      "type": "object",      "additionalProperties": false,      "required": [        "QuizId",        "Difficulty",        "CompletedAtUtc"      ],      "anyOf": [        { "required": ["CategoryId"] },        { "required": ["category"] }      ],      "oneOf": [        { "required": ["ScorePercent"] },        { "required": ["percent"] }      ],      "properties": {        "QuizId": { "type": "string", "minLength": 1 },        "CategoryId": { "type": "string", "minLength": 1 },        "category": { "type": "string", "minLength": 1, "description": "Legacy alias of CategoryId." },        "Difficulty": { "$ref": "#/$defs/Difficulty" },        "ScorePercent": { "type": "number", "minimum": 0, "maximum": 100 },        "percent": { "type": "number", "minimum": 0, "maximum": 100, "description": "Legacy alias of ScorePercent." },        "CompletedAtUtc": { "$ref": "#/$defs/UtcDateTime" },        "takenAtUtc": { "$ref": "#/$defs/UtcDateTime", "description": "Legacy alias of CompletedAtUtc." },        "TotalQuestions": { "type": "integer", "minimum": 0 },        "Correct": { "type": "integer", "minimum": 0 },        "MinutesSpent": { "type": "number", "minimum": 0 }      }    }  }}
