{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://codivium.example/schema/dashboard-payload-v2.schema.json",
  "title": "Codivium Dashboard Payload v2",
  "type": "object",
  "required": [
    "version",
    "meta",
    "overall",
    "combinedCoding",
    "micro",
    "interview",
    "mcq"
  ],
  "additionalProperties": true,
  "properties": {
    "_demoName": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "const": "dashboard-payload-v2"
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "sessionStartEndpoint": {
          "type": "string"
        },
        "anchorDate": {
          "type": "string"
        },
        "ui": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "full",
                "info_only"
              ]
            },
            "panels": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "scores": {
                  "type": "boolean"
                },
                "depth": {
                  "type": "boolean"
                },
                "heatmap": {
                  "type": "boolean"
                },
                "time": {
                  "type": "boolean"
                },
                "allocation": {
                  "type": "boolean"
                },
                "mcq": {
                  "type": "boolean"
                },
                "infoPane": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      }
    },
    "overall": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "metrics",
        "timeOnPlatform",
        "insights"
      ],
      "properties": {
        "metrics": {
          "type": "object",
          "additionalProperties": true
        },
        "timeOnPlatform": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "daily"
          ],
          "properties": {
            "daily": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "date",
                  "minutes"
                ],
                "additionalProperties": true,
                "properties": {
                  "date": {
                    "type": "string"
                  },
                  "minutes": {
                    "type": "number"
                  }
                }
              }
            }
          }
        },
        "insights": {
          "type": "object",
          "additionalProperties": true
        },
        "recommendedActions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "panelId": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "actionType": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "track": {
                "type": "string"
              },
              "params": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        }
      }
    },
    "combinedCoding": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "allocation",
        "depthByCategory",
        "depthAvg",
        "convergenceHeatmap"
      ],
      "properties": {
        "allocation": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "category",
              "minutes",
              "solved"
            ],
            "properties": {
              "category": {
                "type": "string"
              },
              "minutes": {
                "type": "number"
              },
              "solved": {
                "type": "number"
              }
            }
          }
        },
        "depthByCategory": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "required": [
                  "category",
                  "depth"
                ],
                "properties": {
                  "category": {
                    "type": "string"
                  },
                  "depth": {
                    "type": "number"
                  }
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "type": "number"
              }
            }
          ]
        },
        "depthAvg": {
          "type": "number"
        },
        "convergenceHeatmap": {
          "$ref": "#/definitions/convergenceHeatmap"
        }
      }
    },
    "micro": {
      "$ref": "#/definitions/trackBlock"
    },
    "interview": {
      "$ref": "#/definitions/trackBlock"
    },
    "mcq": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "mcq"
      ],
      "properties": {
        "metrics": {
          "type": "object",
          "additionalProperties": true
        },
        "mcq": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "byDifficulty"
          ],
          "properties": {
            "byDifficulty": {
              "$ref": "#/definitions/byDifficulty"
            },
            "byDifficultyEvidence": {
              "$ref": "#/definitions/byDifficultyEvidence"
            },
            "overallCorrect": {
              "type": "object",
              "additionalProperties": true,
              "required": [
                "correct",
                "total"
              ],
              "properties": {
                "correct": {
                  "type": "number"
                },
                "total": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "trackBlock": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "convergenceHeatmap"
      ],
      "properties": {
        "metrics": {
          "type": "object",
          "additionalProperties": true
        },
        "allocation": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "depthByCategory": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "type": "number"
              }
            }
          ]
        },
        "depthAvg": {
          "type": "number"
        },
        "convergenceHeatmap": {
          "$ref": "#/definitions/convergenceHeatmap"
        }
      }
    },
    "convergenceHeatmap": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "categories",
        "buckets",
        "values",
        "counts"
      ],
      "properties": {
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "buckets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "values": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": [
                "number",
                "null"
              ]
            }
          }
        },
        "counts": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": [
                "number",
                "null"
              ]
            }
          }
        },
        "focus": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "modes": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "defaultModeId": {
              "type": "string"
            },
            "rankings": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "topNDefault": {
              "type": "number"
            },
            "topNOptions": {
              "type": "array",
              "items": {
                "type": "number"
              }
            }
          }
        }
      }
    },
    "byDifficulty": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "basic": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        },
        "intermediate": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        },
        "advanced": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        }
      }
    },
    "byDifficultyEvidence": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "basic": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/evidenceItem"
          }
        },
        "intermediate": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/evidenceItem"
          }
        },
        "advanced": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/evidenceItem"
          }
        }
      }
    },
    "evidenceItem": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "attempts": {
          "type": "number"
        },
        "questions": {
          "type": "number"
        }
      }
    }
  }
}